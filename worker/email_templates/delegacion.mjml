<mjml>
    <mj-head>
        <mj-attributes>
            <mj-text
                align="center"
                color="#555"
                font-family="Helvetica, Arial"
                font-size="14px"
            />

            <mj-column padding="0 14px" />
        </mj-attributes>
    </mj-head>

    <mj-body background-color="#eee">
        <mj-hero
            background-width="600px"
            background-url="https://smmun.com/assets/img/email/header.png"
            background-color="#ea6880"
            padding="12% 0"
        >
        </mj-hero>

        <mj-section background-color="#fff">
            <mj-column>
                <mj-text align="left">
                    <h1>¡Muchas gracias!</h1>
                    Hemos recibido tu inscripción. Te haremos llegar
                    próximamente tu asignación y otra información importante,
                    así que estate pendiente de tu correo.
                </mj-text>
            </mj-column>
        </mj-section>

        <mj-section background-color="#fff" padding="0 25px">
            <mj-column>
                <mj-divider
                    border-width="1px"
                    border-style="dashed"
                    border-color="lightgrey"
